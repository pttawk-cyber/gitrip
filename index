<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>2026 Melbourne Journey｜墨爾本陽光歷史之旅</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700&family=Playfair+Display:wght@500;700&display=swap" rel="stylesheet">

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: 'Noto Serif TC', serif;
      background: linear-gradient(to bottom, #f6ecd7 0%, #f9f4ea 45%, #efe2c6 100%);
      color: #3c2f23;
      line-height: 1.9;
      font-size: 20px;
    }

    header {
      background: linear-gradient(rgba(94, 63, 36, 0.58), rgba(94, 63, 36, 0.68)),
      url('https://images.unsplash.com/photo-1514395462725-fb4566210144?q=80&w=1600&auto=format&fit=crop') center/cover no-repeat;
      color: #fff8ea;
      padding: 90px 20px;
      text-align: center;
      border-bottom: 8px solid #c79b5c;
    }

    header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 58px;
      margin-bottom: 12px;
      letter-spacing: 1px;
    }

    header p {
      font-size: 24px;
      margin: 10px 0;
    }

    .container {
      width: 92%;
      max-width: 1250px;
      margin: 40px auto 80px auto;
    }

    .intro {
      background: rgba(255, 248, 233, 0.92);
      border: 3px solid #d7b078;
      border-radius: 22px;
      padding: 36px;
      margin-bottom: 42px;
      box-shadow: 0 10px 28px rgba(76, 55, 28, 0.12);
    }

    .intro-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 18px;
      margin-top: 20px;
    }

    .intro-card {
      background: #fffdf7;
      border-left: 8px solid #d8a25c;
      padding: 20px;
      border-radius: 14px;
    }

    .intro-card h3 {
      margin-top: 0;
      font-size: 24px;
      color: #7b4b1e;
    }

    .day-card {
      background: rgba(255,255,255,0.94);
      border-radius: 26px;
      overflow: hidden;
      margin-bottom: 36px;
      box-shadow: 0 12px 30px rgba(89, 61, 30, 0.14);
      border: 2px solid rgba(184, 136, 75, 0.28);
    }

    .day-header {
      background: linear-gradient(to right, #b87a39, #d6a25f);
      color: #fff;
      padding: 24px 30px;
    }

    .day-header h2 {
      margin: 0;
      font-size: 36px;
      font-family: 'Playfair Display', serif;
    }

    .day-header p {
      margin: 8px 0 0 0;
      font-size: 22px;
    }

    .timeline {
      padding: 28px;
    }

    .event {
      display: flex;
      gap: 24px;
      margin-bottom: 28px;
      padding-bottom: 24px;
      border-bottom: 1px dashed #d5b487;
    }

    .event:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .time {
      min-width: 170px;
      font-weight: 700;
      color: #8b4d14;
      font-size: 22px;
    }

    .details {
      flex: 1;
    }

    .details h3 {
      margin: 0 0 10px 0;
      font-size: 28px;
      color: #4a2f16;
    }

    .location {
      margin-top: 10px;
      color: #65452a;
      font-size: 19px;
    }

    a.map-link {
      display: inline-block;
      margin-top: 14px;
      background: #c98b42;
      color: white;
      text-decoration: none;
      padding: 12px 20px;
      border-radius: 999px;
      font-size: 18px;
      transition: 0.25s ease;
      font-weight: 700;
    }

    a.map-link:hover {
      background: #9f6727;
      transform: translateY(-2px);
    }

    footer {
      text-align: center;
      padding: 50px 20px 70px;
      color: #6a4d2f;
      font-size: 18px;
    }

    .badge {
      display: inline-block;
      background: #f0d7af;
      color: #7d4f1f;
      border-radius: 999px;
      padding: 6px 14px;
      margin-top: 10px;
      font-size: 16px;
      font-weight: 700;
    }

    @media (max-width: 768px) {
      body {
        font-size: 18px;
      }

      header h1 {
        font-size: 42px;
      }

      .event {
        flex-direction: column;
        gap: 10px;
      }

      .time {
        min-width: auto;
      }

      .details h3 {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>

